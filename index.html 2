    <script>
        const menuBtn = document.getElementById('menu-btn');
        const menuClose = document.getElementById('menu-close');
        const mobileMenu = document.getElementById('mobile-menu');
        function toggleMenu() { mobileMenu.classList.toggle('active'); }
        menuBtn.addEventListener('click', toggleMenu);
        menuClose.addEventListener('click', toggleMenu);

        window.addEventListener('scroll', () => {
            const h = document.documentElement, b = document.body, st = 'scrollTop', sh = 'scrollHeight';
            const percent = (h[st] || b[st]) / ((h[sh] || b[sh]) - h.clientHeight) * 100;
            document.getElementById('scroll-progress').style.width = percent + "%";
            const nav = document.getElementById('navbar');
            nav.classList.toggle('scrolled', window.scrollY > 50);
        });

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in-view');
                    if (entry.target.classList.contains('stat-num')) startCount(entry.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal, .stat-num, .why-pal-premium, .palji-section-premium').forEach(el => observer.observe(el));

        function startCount(el) {
            if (el.dataset.done) return;
            el.dataset.done = "true";
            const target = parseInt(el.dataset.target);
            const duration = 2500;
            const startTime = performance.now();
            const plusSpan = el.querySelector('span') ? el.querySelector('span').innerText : '';
            function update(now) {
                const elapsed = now - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const easeOutExpo = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
                const current = Math.floor(easeOutExpo * target);
                if (el.dataset.target === "1956") el.innerText = current;
                else el.innerHTML = `${current}<span>${plusSpan}</span>`;
                if (progress < 1) requestAnimationFrame(update);
                else {
                    if (el.dataset.target === "1956") el.innerText = target;
                    else el.innerHTML = `${target}<span>${plusSpan}</span>`;
                }
            }
            requestAnimationFrame(update);
        }

        const kineticEl = document.getElementById('kinetic-word');
        const kineticWords = ["EST. 1956", "PALJI", "QUALITY", "TRUSTED", "GONDA'S BEST"];
        let wordIdx = 0;
        setInterval(() => {
            kineticEl.style.transform = "translateY(-40px)";
            kineticEl.style.opacity = 0;
            setTimeout(() => {
                wordIdx = (wordIdx + 1) % kineticWords.length;
                kineticEl.innerText = kineticWords[wordIdx];
                kineticEl.style.transform = "translateY(40px)";
                kineticEl.offsetHeight; 
                kineticEl.style.transform = "translateY(0)";
                kineticEl.style.opacity = 1;
            }, 600);
        }, 3000);

        window.onload = () => {
            document.querySelectorAll('#hero .reveal').forEach((el, i) => {
                setTimeout(() => el.classList.add('in-view'), 200 + (i * 120));
            });
        };
    </script>
